{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"[Console]::In.ReadToEnd() | Add-Content -Path '.github/hooks/agent_log.txt'\""      }
    ],
    "preToolUse": [
      {
        "type": "command",
       "command": "powershell.exe -ExecutionPolicy Bypass -Command \"[Console]::In.ReadToEnd() | Add-Content -Path '.github/hooks/agent_log.txt'\""      }
      
    ]
  }
}