@model List<manage_my_hairsaloon.Models.User>
@{
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <h1>Users</h1>
</div>

<div class="table-responsive">
    <table class="table-barbershop">
        <thead>
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Role</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FirstName</td>
                    <td>@user.LastName</td>
                    <td>@user.Email</td>
                    <td>@user.PhoneNumber</td>
                    <td><span class="badge-brass">@user.Role</span></td>
                    <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-controller="Users" asp-action="Details" asp-route-id="@user.Id" class="btn-outline-brass" style="font-size:0.72rem; padding:0.25rem 0.7rem;">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
