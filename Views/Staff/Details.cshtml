@model manage_my_hairsaloon.Models.Staff
@{
    ViewData["Title"] = $"{Model.User?.FirstName} {Model.User?.LastName} — Staff";
    var returnUrl = Context.Request.Query["returnUrl"].FirstOrDefault();
}

<div class="page-header">
    <h1>@Model.User?.FirstName @Model.User?.LastName</h1>
</div>

<div class="card-barbershop">
    <dl class="detail-list">
        <dt>Specialization</dt>
        <dd>@Model.Specialization</dd>

        <dt>Hourly Rate</dt>
        <dd>@Model.HourlyRate.ToString("C")</dd>

        <dt>Availability</dt>
        <dd>
            @if (Model.IsAvailable)
            {
                <span class="badge-available" style="padding:0.25em 0.6em; border-radius:2px; font-size:0.72rem; font-weight:700; text-transform:uppercase;">Available</span>
            }
            else
            {
                <span class="badge-unavailable" style="padding:0.25em 0.6em; border-radius:2px; font-size:0.72rem; font-weight:700; text-transform:uppercase;">Unavailable</span>
            }
        </dd>
    </dl>
</div>

<div class="row g-4">
    @if (Model.User != null)
    {
        <div class="col-md-6">
            <h2 class="section-title">User Info</h2>
            <div class="card-barbershop">
                <dl class="detail-list">
                    <dt>Email</dt>
                    <dd>@Model.User.Email</dd>
                    <dt>Phone</dt>
                    <dd>@Model.User.PhoneNumber</dd>
                    <dt>Role</dt>
                    <dd><span class="badge-brass">@Model.User.Role</span></dd>
                </dl>
                <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.UserId" asp-route-returnUrl="@Context.Request.PathBase@Context.Request.Path@Context.Request.QueryString" class="btn-outline-brass" style="font-size:0.72rem; padding:0.25rem 0.7rem;">View User Profile</a>
            </div>
        </div>
    }
    @if (Model.HairSalon != null)
    {
        <div class="col-md-6">
            <h2 class="section-title">Salon</h2>
            <div class="card-barbershop">
                <dl class="detail-list">
                    <dt>Salon Name</dt>
                    <dd>@Model.HairSalon.Name</dd>
                    <dt>Address</dt>
                    <dd>@Model.HairSalon.Address</dd>
                </dl>
                <a asp-controller="HairSalons" asp-action="Details" asp-route-id="@Model.HairSalonId" asp-route-returnUrl="@Context.Request.PathBase@Context.Request.Path@Context.Request.QueryString" class="btn-outline-brass" style="font-size:0.72rem; padding:0.25rem 0.7rem;">View Salon</a>
            </div>
        </div>
    }
</div>

@if (Model.Reservations != null && Model.Reservations.Any())
{
    <div class="divider-ornament">— ◆ —</div>
    <h2 class="section-title">Reservations</h2>
    <div class="table-responsive">
        <table class="table-barbershop">
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Service</th>
                    <th>Date &amp; Time</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var res in Model.Reservations)
                {
                    <tr>
                        <td>@res.Customer?.FirstName @res.Customer?.LastName</td>
                        <td>@res.Service?.Name</td>
                        <td>@res.ReservationDateTime.ToString("dd MMM yyyy, HH:mm")</td>
                        <td>
                            @{
                                var statusClass = res.Status switch
                                {
                                    ReservationStatus.Pending => "badge-status-pending",
                                    ReservationStatus.Confirmed => "badge-status-confirmed",
                                    ReservationStatus.Completed => "badge-status-completed",
                                    ReservationStatus.Cancelled => "badge-status-cancelled",
                                    ReservationStatus.NoShow => "badge-status-noshow",
                                    _ => "badge-brass"
                                };
                            }
                            <span class="@statusClass" style="padding:0.25em 0.6em; border-radius:2px; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em;">@res.Status</span>
                        </td>
                        <td>
                            <a asp-controller="Reservations" asp-action="Details" asp-route-id="@res.Id" asp-route-returnUrl="@Context.Request.PathBase@Context.Request.Path@Context.Request.QueryString" class="btn-outline-brass" style="font-size:0.72rem; padding:0.25rem 0.7rem;">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(returnUrl) && Url.IsLocalUrl(returnUrl))
{
    <a href="@returnUrl" class="back-link">← Back</a>
}
else
{
    <a asp-controller="Staff" asp-action="Index" class="back-link">← Back to Staff</a>
}
