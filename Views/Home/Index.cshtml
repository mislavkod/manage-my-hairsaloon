@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h1>The Gentleman's Parlour</h1>
</div>

<div class="text-center mb-4">
    <p style="font-family: var(--font-body); color: var(--clr-sand); font-size: 1.05rem; letter-spacing: 0.06em;">
        Welcome to your salon management dashboard. Select a section below to get started.
    </p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-6 col-md-3">
        <a asp-controller="HairSalons" asp-action="Index" style="text-decoration:none;">
            <div class="stat-card">
                <div class="stat-icon">✂</div>
                <div class="stat-label">Hair Salons</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Staff" asp-action="Index" style="text-decoration:none;">
            <div class="stat-card">
                <div class="stat-icon">👤</div>
                <div class="stat-label">Staff</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Services" asp-action="Index" style="text-decoration:none;">
            <div class="stat-card">
                <div class="stat-icon">💈</div>
                <div class="stat-label">Services</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Reservations" asp-action="Index" style="text-decoration:none;">
            <div class="stat-card">
                <div class="stat-icon">📅</div>
                <div class="stat-label">Reservations</div>
            </div>
        </a>
    </div>
</div>

<div class="divider-ornament">— ◆ ◆ ◆ —</div>

<div class="row g-4 justify-content-center">
    <div class="col-6 col-md-3">
        <a asp-controller="Users" asp-action="Index" style="text-decoration:none;">
            <div class="stat-card">
                <div class="stat-icon">👥</div>
                <div class="stat-label">Users</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Reviews" asp-action="Index" style="text-decoration:none;">
            <div class="stat-card">
                <div class="stat-icon">★</div>
                <div class="stat-label">Reviews</div>
            </div>
        </a>
    </div>
</div>
