@model List<manage_my_hairsaloon.Models.Service>
@{
    ViewData["Title"] = "Services";
}

<div class="page-header">
    <h1>Services</h1>
</div>

<div class="table-responsive">
    <table class="table-barbershop">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Duration</th>
                <th>Category</th>
                <th>Salon</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var service in Model)
            {
                <tr>
                    <td>@service.Name</td>
                    <td>@(service.Description?.Length > 60 ? service.Description.Substring(0, 60) + "…" : service.Description)</td>
                    <td>@service.Price.ToString("C")</td>
                    <td>@service.DurationMinutes min</td>
                    <td><span class="badge-brass">@service.Category</span></td>
                    <td>@service.HairSalon?.Name</td>
                    <td>
                        <a asp-controller="Services" asp-action="Details" asp-route-id="@service.Id" class="btn-outline-brass" style="font-size:0.72rem; padding:0.25rem 0.7rem;">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
